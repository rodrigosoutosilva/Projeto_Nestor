# Copie este arquivo para secrets.toml e preencha com suas chaves
# No Streamlit Cloud, configure em: App Settings > Secrets

GEMINI_API_KEY = "sua-chave-api-aqui"

# Banco de dados PostgreSQL (Supabase)
# Vá em: Supabase > Settings > Database > Connection String (URI)
DATABASE_URL = "postgresql://postgres.[ref]:[senha]@aws-0-[region].pooler.supabase.com:6543/postgres"
